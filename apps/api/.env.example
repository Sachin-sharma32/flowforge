# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/flowforge

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# App URL (for billing redirects)
WEB_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Email Verification
AUTH_EMAIL_VERIFICATION_EXPIRY=24h
EMAIL_FROM=no-reply@flowforge.dev
# Optional SMTP settings. If omitted, verification links are logged in development/test.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# OAuth (Google/GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_PRICE_PRO_MONTHLY=price_change_me

# Plan Limits
FREE_EXECUTION_LIMIT=1000
PRO_EXECUTION_LIMIT=10000
ENTERPRISE_EXECUTION_LIMIT=100000
