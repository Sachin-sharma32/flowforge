# ============================================================
# FlowForge — Complete Environment Variables for Deployment
# ============================================================
# Copy this file and fill in values for your deployment target.
# The API reads from apps/api/.env (or process env).
# The web app reads from apps/web/.env.local (or process env).
# ============================================================

# ── API Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/flowforge?retryWrites=true&w=majority
REDIS_URL=redis://<user>:<password>@<host>:6379

# ── JWT / Auth ──────────────────────────────────────────────
JWT_SECRET=<generate-a-64-char-random-string>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie settings (adjust for your domain)
AUTH_REFRESH_COOKIE_NAME=ff_refresh
AUTH_CSRF_COOKIE_NAME=ff_csrf
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_CSRF_COOKIE_PATH=/
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=true
AUTH_EMAIL_VERIFICATION_EXPIRY=24h
AUTH_REFRESH_REPLAY_TTL_SECONDS=3600
AUTH_REFRESH_SESSION_LIMIT=5

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── URLs ────────────────────────────────────────────────────
WEB_APP_URL=https://your-domain.com
API_PUBLIC_URL=https://api.your-domain.com

# ── Email (SMTP) ───────────────────────────────────────────
EMAIL_FROM=no-reply@your-domain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false

# ── OAuth Providers (optional) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe Billing ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ── Plan Limits ─────────────────────────────────────────────
FREE_EXECUTION_LIMIT=1000
PRO_EXECUTION_LIMIT=10000
ENTERPRISE_EXECUTION_LIMIT=100000

# ── Web App (Next.js) ──────────────────────────────────────
# Set in apps/web/.env.local or as a process env var
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1
